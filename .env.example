# =============================================================================
# MiraiDroid .env example
# Copy this file to .env and fill in your real values.
# DO NOT commit the real .env file (it's already in .gitignore).
# =============================================================================

# --- Telegram ---
# Get from @BotFather on Telegram
TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Your numeric Telegram user ID (you can get it from @userinfobot)
OWNER_ID=123456789

# --- AI providers ---
# MiniMax API key (primary LLM provider)
MINIMAX_KEY=your_minimax_api_key_here

# Groq API key (fallback LLM + Whisper transcription)
GROQ_API_KEY=your_groq_api_key_here

# --- Web search ---
# Tavily API key (primary search; falls back to DuckDuckGo if missing)
TAVILY_API_KEY=your_tavily_api_key_here